{
  "rewrites": [
    {
      "source": "/api/openai/:match*",
      "destination": "https://api.openai.com/:match*"
    },
    {
      "source": "/api/fish/:match*",
      "destination": "https://api.fish.audio/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
